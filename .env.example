# MMProtect License Server — environment configuration template
#
# Copy to .env and fill in your values:
#   cp .env.example .env && chmod 600 .env
#
# NEVER commit .env to version control.
# Variable reference: see docker-compose.yml / docker-compose.sqlite.yml

# ── Port ────────────────────────────────────────────────────────────────────
# External host port AND internal listen port for the license server.
MMPROTECT_PORT=8080

# ── MySQL credentials (docker-compose.yml only) ──────────────────────────────
# These variables are shared between the mysql service and the connection string.
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=mm_license
MYSQL_USER=mm_license
MYSQL_PASSWORD=change-me-db-password

# ── Database provider ────────────────────────────────────────────────────────
# mysql  → uses ConnectionStrings__MySql  (default for docker-compose.yml)
# sqlite → uses ConnectionStrings__Sqlite (default for docker-compose.sqlite.yml)
MMPROTECT_DB_PROVIDER=mysql

# Advanced: override the full MySQL connection string (optional).
# When set, takes precedence over the MYSQL_* variables above.
# MMPROTECT_MYSQL_CONNSTR=Server=db.example.com;Port=3306;Database=mm_license;User Id=mm_license;Password=secret;SslMode=Required;

# SQLite DB path inside the container (for docker-compose.sqlite.yml).
# MMPROTECT_SQLITE_CONNSTR=Data Source=/var/cache/mmprotect/mm_license.db

# ── API Keys ─────────────────────────────────────────────────────────────────
# Static keys checked at startup (no restart needed for additional keys added
# via Admin API at /api/v1/admin/api-clients).
#
# Key 0 is required. Add more static keys:
#   Security__EncoderApiKeys__1=another-encoder-key   (in docker run -e / .env)
#   Security__AdminApiKeys__1=another-admin-key
MMPROTECT_ENCODER_API_KEY_0=change-me-encoder-api-key
MMPROTECT_ADMIN_API_KEY_0=change-me-admin-api-key

# ── AES-256-GCM Key Encryption Key (KEK) ─────────────────────────────────────
# Wraps build keys stored in the database. Required in production.
# Generate:  openssl rand -hex 32
# Leave empty for dev (keys stored unencrypted — server logs a warning).
MMPROTECT_KEK=

# ── ECDSA-P256 Signing Key ───────────────────────────────────────────────────
# Private key used to sign runtime leases.
# Required in production; leaving unset falls back to HMAC-SHA256 (dev warning).
#
# MMPROTECT_SIGNING_KEY_HOST_PATH is the path ON THE HOST to the PEM file.
# The compose file mounts it inside the container at /run/secrets/signing-private.pem
# and sets Security__SigningPrivateKeyFile automatically.
#
# Generate:
#   scripts/linux/gen-signing-keys.sh /etc/mmprotect
#   # → /etc/mmprotect/signing-private.pem  (keep secret!)
#   # → /etc/mmprotect/signing-public.pem   (distribute to customers)
#
# MMPROTECT_SIGNING_KEY_HOST_PATH=/etc/mmprotect/signing-private.pem

# ── Lease settings ───────────────────────────────────────────────────────────
# How long a granted lease is valid (minutes).
MMPROTECT_LEASE_TTL_MINUTES=1440
# How long a cached lease is used offline after the server becomes unreachable (days).
MMPROTECT_GRACE_PERIOD_DAYS=7

# ── Reverse Proxy (nginx / Traefik / Caddy) ──────────────────────────────────
# Set to true when the server sits behind a reverse proxy.
MMPROTECT_REVERSE_PROXY_ENABLED=false
# Number of proxy hops to trust for X-Forwarded-For.
MMPROTECT_FORWARD_LIMIT=1

# ── Rate Limiting ────────────────────────────────────────────────────────────
MMPROTECT_RATE_LIMITING_ENABLED=true
# Max lease requests per client IP per window.
MMPROTECT_RATE_LIMIT_PERMITS=10
# Window length in seconds.
MMPROTECT_RATE_LIMIT_WINDOW=60

# ── ASP.NET Core ─────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
