{
  "DatabaseProvider": "mysql",
  "ConnectionStrings": {
    "MySql": "Server=localhost;Port=3306;Database=mm_license;User=mm_license;Password=CHANGE-ME;TreatTinyAsBoolean=true;",
    "Sqlite": "Data Source=/var/lib/mmprotect/mm_license.db"
  },
  "Security": {
    "LeaseTtlMinutes": 1440,
    "GracePeriodDays": 7,
    "EncoderApiKeys": [ "CHANGE-ME-STRONG-RANDOM-KEY" ],
    "SigningPrivateKeyFile": "/etc/mmprotect/signing-private.pem"
  },

  "ReverseProxy": {
    "Enabled": false,
    "TrustedProxies": [
      "127.0.0.1",
      "::1"
    ],
    "TrustedNetworks": [
    ],
    "ForwardLimit": 1
  },

  "RateLimiting": {
    "Enabled": true,
    "LeaseEndpoint": {
      "PermitLimit": 10,
      "WindowSeconds": 60,
      "QueueLimit": 0
    }
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
